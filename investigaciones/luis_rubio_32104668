echo -e "${COLOR_NEGRITA}${COLOR_MAGENTA}📌 INTRODUCCIÓN:${COLOR_RESET}"
echo -e "Las estructuras de control condicionales permiten tomar decisiones en un script"
echo -e "basadas en condiciones lógicas. En Bash, las principales son:"
echo -e "${COLOR_YELLOW}if, elif, else${COLOR_RESET} y ${COLOR_YELLOW}case${COLOR_RESET}."
echo -e "Estas estructuras son fundamentales para crear scripts inteligentes que respondan"
echo -e "a diferentes situaciones y entradas del usuario."
echo ""

echo -e "${COLOR_NEGRITA}${COLOR_MAGENTA}📌 PUNTOS CLAVE DE LA INVESTIGACIÓN:${COLOR_RESET}"
# Ejemplo: párrafo de varias líneas para el punto 1 usando un here-doc

echo -e "${COLOR_BLANCO}  1. ESTRUCTURA IF-ELSE:${COLOR_RESET}"
cat <<EOF
    La estructura if permite ejecutar un bloque de código si se cumple una condición.

    Sintaxis:
      if [ condición ]; then
        # código si se cumple
      else
        # código si no se cumple
      fi

    Ejemplo:
      if [ \$edad -ge 18 ]; then
        echo 'Eres mayor de edad'
      else
        echo 'Eres menor de edad'
      fi
EOF
echo -e "${COLOR_RESET}"

echo -e "${COLOR_YELLOW}  2. ESTRUCTURA ELIF (ELSE IF):${COLOR_RESET}"
cat <<EOF
    Permite evaluar múltiples condiciones en secuencia.

    Sintaxis:
      if [ condición1 ]; then
        # código para condición1
      elif [ condición2 ]; then
        # código para condición2
      else
        # código si ninguna se cumple
      fi

    Ejemplo:
      if [ \$nota -ge 90 ]; then
        echo 'Excelente'
      elif [ \$nota -ge 70 ]; then
        echo 'Aprobado'
      else
        echo 'Reprobado'
      fi
EOF
echo ""

echo -e "${COLOR_BLANCO}  3. ESTRUCTURA CASE (SWITCH):${COLOR_RESET}"
cat <<EOF
    Case es ideal para comparar una variable contra múltiples valores posibles.

    Sintaxis:
      case \$variable in
        valor1)
          # código para valor1
          ;;
        valor2)
          # código para valor2
          ;;
        *)
          # código para cualquier otro valor
          ;;
      esac

    Ejemplo:
      case \$dia in
        lunes)
          echo 'Inicio de semana'
          ;;
        viernes)
          echo 'Fin de semana cercano'
          ;;
        *)
          echo 'Día normal'
          ;;
      esac
EOF
echo ""

echo -e "${COLOR_YELLOW}  4. OPERADORES COMUNES EN CONDICIONALES:${COLOR_RESET}"
cat <<EOF
    -eq : igual (numérico)        -ne : no igual
    -gt : mayor que                -lt : menor que
    -ge : mayor o igual            -le : menor o igual
    =   : igual (cadenas)          !=  : no igual (cadenas)
    -z  : cadena vacía            -n  : cadena no vacía
    -f  : existe archivo          -d  : existe directorio
    -r  : archivo legible         -w  : archivo escribible
EOF
echo ""

echo -e "${COLOR_NEGRITA}${COLOR_MAGENTA}📌 CONCLUSIÓN:${COLOR_RESET}"
